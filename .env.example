# NovaCrawl environment configuration
# Copy this file to .env and edit as needed

# Bind address — use 0.0.0.0 to expose on your local network
HOST_BINDING=127.0.0.1
PORT=5000

# Set to true to skip login (recommended for local single-user use)
LOCAL_MODE=true

# Secret key for Flask sessions — change this to a random string in production
SECRET_KEY=change-me-to-a-random-secret

# --- Multi-user mode only (leave blank for local use) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google PageSpeed Insights API key (optional — needed for Performance tab)
GOOGLE_API_KEY=
